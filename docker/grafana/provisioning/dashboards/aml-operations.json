{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "description": "Métriques opérationnelles AML/KYC — alertes, règles, transactions, scoring ML, screening sanctions",
  "editable": false,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "asDropdown": false,
      "icon": "external link",
      "includeVars": false,
      "keepTime": true,
      "tags": ["kyc"],
      "targetBlank": false,
      "title": "Platform Overview",
      "tooltip": "",
      "type": "dashboards",
      "url": ""
    }
  ],
  "panels": [

    { "collapsed": false, "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "id": 100, "title": "Alertes AML", "type": "row" },

    {
      "id": 1, "gridPos": {"h": 4, "w": 4, "x": 0, "y": 1},
      "type": "stat", "title": "Alertes CRITICAL (24 h)",
      "datasource": {"type": "prometheus", "uid": "kyc-prometheus"},
      "targets": [{"expr": "increase(aml_alerts_total{app=\"kyc-aml-v2\",priority=\"CRITICAL\"}[24h])", "legendFormat": "", "refId": "A"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "area", "textMode": "auto"},
      "fieldConfig": {"defaults": {"decimals": 0, "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 1}, {"color": "red", "value": 5}]}}}
    },

    {
      "id": 2, "gridPos": {"h": 4, "w": 4, "x": 4, "y": 1},
      "type": "stat", "title": "Alertes HIGH (24 h)",
      "datasource": {"type": "prometheus", "uid": "kyc-prometheus"},
      "targets": [{"expr": "increase(aml_alerts_total{app=\"kyc-aml-v2\",priority=\"HIGH\"}[24h])", "legendFormat": "", "refId": "A"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "area", "textMode": "auto"},
      "fieldConfig": {"defaults": {"decimals": 0, "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 3}, {"color": "orange", "value": 10}]}}}
    },

    {
      "id": 3, "gridPos": {"h": 4, "w": 4, "x": 8, "y": 1},
      "type": "stat", "title": "Alertes MEDIUM (24 h)",
      "datasource": {"type": "prometheus", "uid": "kyc-prometheus"},
      "targets": [{"expr": "increase(aml_alerts_total{app=\"kyc-aml-v2\",priority=\"MEDIUM\"}[24h])", "legendFormat": "", "refId": "A"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "area", "textMode": "auto"},
      "fieldConfig": {"defaults": {"decimals": 0, "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 20}]}}}
    },

    {
      "id": 4, "gridPos": {"h": 4, "w": 4, "x": 12, "y": 1},
      "type": "stat", "title": "Transactions analysées (24 h)",
      "datasource": {"type": "prometheus", "uid": "kyc-prometheus"},
      "targets": [{"expr": "increase(aml_transactions_analyzed_total{app=\"kyc-aml-v2\"}[24h])", "legendFormat": "", "refId": "A"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "area", "textMode": "auto"},
      "fieldConfig": {"defaults": {"decimals": 0, "unit": "short", "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}}}
    },

    {
      "id": 5, "gridPos": {"h": 4, "w": 4, "x": 16, "y": 1},
      "type": "stat", "title": "Scoring ML p95 (5 m)",
      "datasource": {"type": "prometheus", "uid": "kyc-prometheus"},
      "targets": [{"expr": "histogram_quantile(0.95, sum(rate(aml_ml_score_duration_seconds_bucket{app=\"kyc-aml-v2\"}[5m])) by (le)) * 1000", "legendFormat": "", "refId": "A"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "area", "textMode": "auto"},
      "fieldConfig": {"defaults": {"unit": "ms", "decimals": 0, "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 1000}, {"color": "red", "value": 3000}]}}}
    },

    {
      "id": 6, "gridPos": {"h": 4, "w": 4, "x": 20, "y": 1},
      "type": "stat", "title": "Screening MATCH (24 h)",
      "datasource": {"type": "prometheus", "uid": "kyc-prometheus"},
      "targets": [{"expr": "increase(screening_checks_total{app=\"kyc-aml-v2\",status=\"MATCH\"}[24h])", "legendFormat": "", "refId": "A"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "area", "textMode": "auto"},
      "fieldConfig": {"defaults": {"decimals": 0, "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "red", "value": 1}]}}}
    },

    {
      "id": 10, "gridPos": {"h": 8, "w": 12, "x": 0, "y": 5},
      "type": "timeseries", "title": "Alertes AML — taux par priorité",
      "datasource": {"type": "prometheus", "uid": "kyc-prometheus"},
      "targets": [
        {"expr": "sum(rate(aml_alerts_total{app=\"kyc-aml-v2\"}[5m])) by (priority)", "legendFormat": "{{priority}}", "refId": "A"}
      ],
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}},
      "fieldConfig": {
        "defaults": {"unit": "cps", "custom": {"lineWidth": 2, "fillOpacity": 15}},
        "overrides": [
          {"matcher": {"id": "byName", "options": "CRITICAL"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "dark-red"}}]},
          {"matcher": {"id": "byName", "options": "HIGH"},     "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "orange"}}]},
          {"matcher": {"id": "byName", "options": "MEDIUM"},   "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "yellow"}}]},
          {"matcher": {"id": "byName", "options": "LOW"},      "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "blue"}}]}
        ]
      }
    },

    {
      "id": 11, "gridPos": {"h": 8, "w": 12, "x": 12, "y": 5},
      "type": "piechart", "title": "Alertes AML — répartition par priorité (24 h)",
      "datasource": {"type": "prometheus", "uid": "kyc-prometheus"},
      "targets": [
        {"expr": "increase(aml_alerts_total{app=\"kyc-aml-v2\"}[24h])", "legendFormat": "{{priority}}", "refId": "A"}
      ],
      "options": {
        "pieType": "pie",
        "tooltip": {"mode": "multi"},
        "legend": {"displayMode": "table", "placement": "right", "values": ["value", "percent"]},
        "displayLabels": ["percent"]
      },
      "fieldConfig": {
        "defaults": {"unit": "short"},
        "overrides": [
          {"matcher": {"id": "byName", "options": "CRITICAL"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "dark-red"}}]},
          {"matcher": {"id": "byName", "options": "HIGH"},     "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "orange"}}]},
          {"matcher": {"id": "byName", "options": "MEDIUM"},   "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "yellow"}}]},
          {"matcher": {"id": "byName", "options": "LOW"},      "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "blue"}}]}
        ]
      }
    },

    { "collapsed": false, "gridPos": {"h": 1, "w": 24, "x": 0, "y": 13},
      "id": 101, "title": "Règles AML & Transactions", "type": "row" },

    {
      "id": 20, "gridPos": {"h": 8, "w": 12, "x": 0, "y": 14},
      "type": "bargauge", "title": "Top 10 règles AML déclenchées (24 h)",
      "datasource": {"type": "prometheus", "uid": "kyc-prometheus"},
      "targets": [
        {"expr": "topk(10, increase(aml_rules_triggered_total{app=\"kyc-aml-v2\"}[24h]))", "legendFormat": "{{rule_id}}", "refId": "A"}
      ],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "orientation": "horizontal",
        "displayMode": "gradient",
        "valueMode": "color",
        "showUnfilled": true
      },
      "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "continuous-BlYlRd"}}}
    },

    {
      "id": 21, "gridPos": {"h": 8, "w": 12, "x": 12, "y": 14},
      "type": "timeseries", "title": "Transactions AML analysées — débit",
      "datasource": {"type": "prometheus", "uid": "kyc-prometheus"},
      "targets": [
        {"expr": "rate(aml_transactions_analyzed_total{app=\"kyc-aml-v2\"}[5m])", "legendFormat": "Transactions/s", "refId": "A"},
        {"expr": "sum(rate(aml_alerts_total{app=\"kyc-aml-v2\"}[5m]))", "legendFormat": "Alertes/s", "refId": "B"}
      ],
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}},
      "fieldConfig": {"defaults": {"unit": "cps", "custom": {"lineWidth": 2}}}
    },

    { "collapsed": false, "gridPos": {"h": 1, "w": 24, "x": 0, "y": 22},
      "id": 102, "title": "Scoring ML Python", "type": "row" },

    {
      "id": 30, "gridPos": {"h": 8, "w": 12, "x": 0, "y": 23},
      "type": "timeseries", "title": "Scoring ML — latence (percentiles)",
      "datasource": {"type": "prometheus", "uid": "kyc-prometheus"},
      "targets": [
        {"expr": "histogram_quantile(0.50, sum(rate(aml_ml_score_duration_seconds_bucket{app=\"kyc-aml-v2\"}[5m])) by (le)) * 1000", "legendFormat": "p50", "refId": "A"},
        {"expr": "histogram_quantile(0.95, sum(rate(aml_ml_score_duration_seconds_bucket{app=\"kyc-aml-v2\"}[5m])) by (le)) * 1000", "legendFormat": "p95", "refId": "B"},
        {"expr": "histogram_quantile(0.99, sum(rate(aml_ml_score_duration_seconds_bucket{app=\"kyc-aml-v2\"}[5m])) by (le)) * 1000", "legendFormat": "p99", "refId": "C"}
      ],
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}},
      "fieldConfig": {
        "defaults": {"unit": "ms", "custom": {"lineWidth": 2}},
        "overrides": [
          {"matcher": {"id": "byName", "options": "p99"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "red"}}]},
          {"matcher": {"id": "byName", "options": "p95"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "orange"}}]},
          {"matcher": {"id": "byName", "options": "p50"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "green"}}]}
        ]
      }
    },

    {
      "id": 31, "gridPos": {"h": 8, "w": 12, "x": 12, "y": 23},
      "type": "timeseries", "title": "Scoring ML — débit (appels/s)",
      "datasource": {"type": "prometheus", "uid": "kyc-prometheus"},
      "targets": [
        {"expr": "rate(aml_ml_score_duration_seconds_count{app=\"kyc-aml-v2\"}[5m])", "legendFormat": "Appels ML/s", "refId": "A"}
      ],
      "options": {"tooltip": {"mode": "single"}, "legend": {"displayMode": "list", "placement": "bottom"}},
      "fieldConfig": {"defaults": {"unit": "cps", "custom": {"lineWidth": 2, "fillOpacity": 15}}}
    },

    { "collapsed": false, "gridPos": {"h": 1, "w": 24, "x": 0, "y": 31},
      "id": 103, "title": "Screening Sanctions", "type": "row" },

    {
      "id": 40, "gridPos": {"h": 8, "w": 8, "x": 0, "y": 32},
      "type": "timeseries", "title": "Screening — taux par résultat",
      "datasource": {"type": "prometheus", "uid": "kyc-prometheus"},
      "targets": [
        {"expr": "sum(rate(screening_checks_total{app=\"kyc-aml-v2\"}[5m])) by (status)", "legendFormat": "{{status}}", "refId": "A"}
      ],
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}},
      "fieldConfig": {
        "defaults": {"unit": "cps", "custom": {"lineWidth": 2, "fillOpacity": 10}},
        "overrides": [
          {"matcher": {"id": "byName", "options": "MATCH"},  "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "red"}}]},
          {"matcher": {"id": "byName", "options": "REVIEW"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "orange"}}]},
          {"matcher": {"id": "byName", "options": "CLEAR"},  "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "green"}}]}
        ]
      }
    },

    {
      "id": 41, "gridPos": {"h": 8, "w": 8, "x": 8, "y": 32},
      "type": "piechart", "title": "Screening — répartition 24 h",
      "datasource": {"type": "prometheus", "uid": "kyc-prometheus"},
      "targets": [
        {"expr": "increase(screening_checks_total{app=\"kyc-aml-v2\"}[24h])", "legendFormat": "{{status}}", "refId": "A"}
      ],
      "options": {
        "pieType": "donut",
        "tooltip": {"mode": "multi"},
        "legend": {"displayMode": "table", "placement": "right", "values": ["value", "percent"]},
        "displayLabels": ["percent"]
      },
      "fieldConfig": {
        "defaults": {"unit": "short"},
        "overrides": [
          {"matcher": {"id": "byName", "options": "MATCH"},  "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "red"}}]},
          {"matcher": {"id": "byName", "options": "REVIEW"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "orange"}}]},
          {"matcher": {"id": "byName", "options": "CLEAR"},  "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "green"}}]}
        ]
      }
    },

    {
      "id": 42, "gridPos": {"h": 8, "w": 8, "x": 16, "y": 32},
      "type": "stat", "title": "Taux de match sanctions (%)",
      "datasource": {"type": "prometheus", "uid": "kyc-prometheus"},
      "targets": [
        {"expr": "increase(screening_checks_total{app=\"kyc-aml-v2\",status=\"MATCH\"}[24h]) / increase(screening_checks_total{app=\"kyc-aml-v2\"}[24h]) * 100", "legendFormat": "", "refId": "A"}
      ],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "area", "textMode": "auto", "orientation": "auto"},
      "fieldConfig": {"defaults": {"unit": "percent", "decimals": 2, "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 0.5}, {"color": "red", "value": 2}]}}}
    },

    { "collapsed": false, "gridPos": {"h": 1, "w": 24, "x": 0, "y": 40},
      "id": 104, "title": "Logs AML (Loki)", "type": "row" },

    {
      "id": 50, "gridPos": {"h": 10, "w": 24, "x": 0, "y": 41},
      "type": "logs", "title": "Logs AML & Screening",
      "datasource": {"type": "loki", "uid": "kyc-loki"},
      "targets": [
        {"expr": "{container=\"kyc_app\"} |= `` | json | module =~ `aml|screening`", "legendFormat": "", "refId": "A"}
      ],
      "options": {"showTime": true, "showLabels": true, "showCommonLabels": false, "wrapLogMessage": true, "prettifyLogMessage": false, "enableLogDetails": true, "dedupStrategy": "none", "sortOrder": "Descending"}
    }

  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["kyc", "aml", "compliance"],
  "templating": {"list": []},
  "time": {"from": "now-6h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "KYC-AML — Opérations AML",
  "uid": "kyc-aml-operations",
  "version": 1
}
