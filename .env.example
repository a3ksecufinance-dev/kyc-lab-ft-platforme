# ─── KYC-AML Platform — Variables d'environnement ────────────────────────────
# Copier ce fichier en .env (dev) ou générer .env.production avec :
#   ./scripts/generate-secrets.sh
#
# ⚠️  Ne jamais committer .env.production — il contient des secrets réels

NODE_ENV=development
PORT=3000

# ─── Base de données ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql://kyc_user:kyc_password@localhost:5432/kyc_aml_db

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ─── JWT — GÉNÉRER avec : openssl rand -hex 32 ────────────────────────────────
JWT_ACCESS_SECRET=GENERATE_WITH_openssl_rand_hex_32
JWT_REFRESH_SECRET=GENERATE_WITH_openssl_rand_hex_32_DIFFERENT

# ─── Compte admin initial ─────────────────────────────────────────────────────
ADMIN_EMAIL=admin@kyc-aml.local
ADMIN_PASSWORD=ChangeMe!Admin123
ADMIN_NAME=Administrateur

# ─── Chiffrement PII (AES-256-GCM) — optionnel en dev, OBLIGATOIRE en prod ────
# Générer : openssl rand -hex 32
PII_ENCRYPTION_KEY=

# ─── MFA TOTP ────────────────────────────────────────────────────────────────
MFA_ENCRYPTION_KEY=GENERATE_WITH_openssl_rand_hex_32

# ─── ML Service ──────────────────────────────────────────────────────────────
ML_SERVICE_URL=http://kyc_ml:8000
ML_INTERNAL_API_KEY=dev_ml_key_changeme_in_prod
ML_RETRAIN_AUTO=true
ML_RETRAIN_CRON=0 3 * * 0
ML_RETRAIN_DAYS_HISTORY=180

# ─── pKYC — Perpetual KYC (dérive comportementale nuitière) ──────────────────
PKYC_ENABLED=true
PKYC_CRON=0 1 * * *          # 01:00 UTC chaque nuit
PKYC_DRIFT_THRESHOLD=40      # 0-100 : au-dessus → revue KYC déclenchée
PKYC_BASELINE_DAYS=30        # fenêtre de référence (jours)
PKYC_WINDOW_DAYS=7           # fenêtre d'analyse récente (jours)

# ─── Screening — listes sanctions publiques ───────────────────────────────────
OFAC_SDN_URL=https://www.treasury.gov/ofac/downloads/sdn.xml
EU_SANCTIONS_URL=https://webgate.ec.europa.eu/fsd/fsf/public/files/xmlFullSanctionsList_1_1/content
UN_SANCTIONS_URL=https://scsanctions.un.org/resources/xml/en/consolidated.xml
UK_SANCTIONS_URL=https://assets.publishing.service.gov.uk/media/uk-sanctions-list.xml
# PEP — Personnes Politiquement Exposées (OpenSanctions, gratuit non-commercial)
PEP_LIST_URL=https://data.opensanctions.org/datasets/latest/peps/targets.simple.csv
# BAM / ANRF — liste nationale marocaine (URL fournie sur agrément BAM)
BAM_SANCTIONS_URL=
# Alerte si liste non mise à jour depuis X heures
SCREENING_STALE_THRESHOLD_HOURS=36
SCREENING_MATCH_THRESHOLD=80
SCREENING_REVIEW_THRESHOLD=50
SCREENING_AUTO_UPDATE=true
SCREENING_UPDATE_CRON=0 2 * * *

# ─── Règles AML ───────────────────────────────────────────────────────────────
AML_THRESHOLD_SINGLE_TX=10000
AML_THRESHOLD_STRUCTURING=3000
AML_STRUCTURING_WINDOW_HOURS=24
AML_FREQUENCY_THRESHOLD=10
AML_VOLUME_VARIATION_THRESHOLD=300

# ─── TRACFIN ──────────────────────────────────────────────────────────────────
TRANSMISSION_MODE=SIMULATION
TRACFIN_ENTITY_ID=TR-2024-VOTRE-ID
ORG_NAME=Votre Banque SA
ORG_ADDRESS=1 Rue de la Compliance
ORG_CITY=Paris
ORG_POSTAL_CODE=75001
ORG_COUNTRY=FR
ORG_PHONE=+33100000000
ORG_EMAIL=compliance@votre-banque.fr

# ─── eKYC ────────────────────────────────────────────────────────────────────
EKYC_PROVIDER=local
# ONFIDO_API_TOKEN=
# SUMSUB_APP_TOKEN=
# SUMSUB_SECRET_KEY=

# ─── Webhook ─────────────────────────────────────────────────────────────────
WEBHOOK_SECRET=GENERATE_WITH_openssl_rand_hex_32

# ─── Stockage ─────────────────────────────────────────────────────────────────
STORAGE_BACKEND=local
UPLOAD_DIR=./uploads
UPLOAD_MAX_SIZE_MB=10

# ─── HashiCorp Vault (optionnel) ──────────────────────────────────────────────
# VAULT_ADDR=https://vault.votre-domaine.fr
# VAULT_TOKEN=hvs.XXXXX
# VAULT_PATH=secret/data/kyc-aml

# ─── Rate limiting & CORS ────────────────────────────────────────────────────
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_SECONDS=60
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── Logs ─────────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FORMAT=pretty
